# Azure OpenAI (legacy)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2023-05-15
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# OpenAI API (paper upload metadata extraction)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Database setting

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,202.191.56.91,www.google.com,be-staging-ai-research.hust.edu.vn
POSTGRES_DB=<db_name>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<password>
POSTGRES_HOST=<postgres_host> # should be localhost
POSTGRES_PORT=<port> # 5432 default


# Single Sign On
GOOGLE_CLIENT_ID="replace this"
GOOGLE_CLIENT_SECRET="replace this"

MICROSOFT_CLIENT_ID="replace this"
MICROSOFT_CLIENT_SECRET="replace this"

# Frontend
FRONTEND_URL="http://127.0.0.1:3000"
API_URL="https://0.0.0.0:8000"

# Research assistant (Docker: http://research-assistant:8001)
RESEARCH_ASSISTANT_URL=http://localhost:8001

# Auto venue mapping (upload + crawler callback)
VENUE_OK_AUTO_FUZZY=92
INTERNAL_VENUE_MAP_KEY=local-dev-internal